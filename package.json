{
  "name": "playwright-hammerhead",
  "version": "0.0.1",
  "description": "Playwright-compatible API layer for Safari automation via testcafe-hammerhead proxy",
  "homepage": "https://github.com/AlexGalichenko/playwright-hammerhead#readme",
  "bugs": {
    "url": "https://github.com/AlexGalichenko/playwright-hammerhead/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AlexGalichenko/playwright-hammerhead.git"
  },
  "license": "ISC",
  "author": "AlexGalichenko",
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "prepare": "npm run build",
    "debug": "playwright test --config tests/playwright.config.ts --ui",
    "test": "playwright test --config tests/playwright.config.ts --project=e2e"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.8.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "modern-screenshot": "^4.7.0",
    "testcafe-hammerhead": "^31.7.7"
  }
}
